{
    "functions": {
        "api/index.php":                      { "runtime": "vercel-php@0.7.1" },
        "api/login.php":                      { "runtime": "vercel-php@0.7.1" },
        "api/logout.php":                     { "runtime": "vercel-php@0.7.1" },
        "api/register.php":                   { "runtime": "vercel-php@0.7.1" },
        "api/dashboard.php":                  { "runtime": "vercel-php@0.7.1" },
        "api/patients/index.php":             { "runtime": "vercel-php@0.7.1" },
        "api/patients/add.php":               { "runtime": "vercel-php@0.7.1" },
        "api/patients/edit.php":              { "runtime": "vercel-php@0.7.1" },
        "api/patients/view.php":              { "runtime": "vercel-php@0.7.1" },
        "api/patients/delete.php":            { "runtime": "vercel-php@0.7.1" },
        "api/patients/my_records.php":        { "runtime": "vercel-php@0.7.1" },
        "api/queues/index.php":               { "runtime": "vercel-php@0.7.1" },
        "api/queues/create.php":              { "runtime": "vercel-php@0.7.1" },
        "api/medical_records/index.php":      { "runtime": "vercel-php@0.7.1" },
        "api/medical_records/create.php":     { "runtime": "vercel-php@0.7.1" },
        "api/medical_records/new.php":        { "runtime": "vercel-php@0.7.1" },
        "api/medical_records/view.php":       { "runtime": "vercel-php@0.7.1" },
        "api/initial_checks/index.php":       { "runtime": "vercel-php@0.7.1" },
        "api/initial_checks/create.php":      { "runtime": "vercel-php@0.7.1" },
        "api/admin/users.php":                { "runtime": "vercel-php@0.7.1" },
        "api/apb/queue_action.php":           { "runtime": "vercel-php@0.7.1" },
        "api/apb/search_patients.php":        { "runtime": "vercel-php@0.7.1" }
    },
    "routes": [
        { "src": "/public/css/(.*\\.css)",  "dest": "/public/css/$1",  "headers": { "Content-Type": "text/css; charset=utf-8",         "Cache-Control": "public, max-age=31536000, immutable" } },
        { "src": "/public/js/(.*\\.js)",    "dest": "/public/js/$1",   "headers": { "Content-Type": "application/javascript; charset=utf-8", "Cache-Control": "public, max-age=31536000, immutable" } },
        { "handle": "filesystem" },
        { "src": "/dashboard(.*)",             "dest": "/api/dashboard.php" },
        { "src": "/login(.*)",                 "dest": "/api/login.php" },
        { "src": "/logout(.*)",                "dest": "/api/logout.php" },
        { "src": "/register(.*)",              "dest": "/api/register.php" },
        { "src": "/patients/add(.*)",          "dest": "/api/patients/add.php" },
        { "src": "/patients/edit(.*)",         "dest": "/api/patients/edit.php" },
        { "src": "/patients/view(.*)",         "dest": "/api/patients/view.php" },
        { "src": "/patients/delete(.*)",       "dest": "/api/patients/delete.php" },
        { "src": "/patients/my_records(.*)",   "dest": "/api/patients/my_records.php" },
        { "src": "/patients(.*)",              "dest": "/api/patients/index.php" },
        { "src": "/queues/create(.*)",         "dest": "/api/queues/create.php" },
        { "src": "/queues(.*)",                "dest": "/api/queues/index.php" },
        { "src": "/medical_records/create(.*)", "dest": "/api/medical_records/create.php" },
        { "src": "/medical_records/new(.*)",   "dest": "/api/medical_records/new.php" },
        { "src": "/medical_records/view(.*)",  "dest": "/api/medical_records/view.php" },
        { "src": "/medical_records(.*)",       "dest": "/api/medical_records/index.php" },
        { "src": "/initial_checks/create(.*)", "dest": "/api/initial_checks/create.php" },
        { "src": "/initial_checks(.*)",        "dest": "/api/initial_checks/index.php" },
        { "src": "/admin/users(.*)",           "dest": "/api/admin/users.php" },
        { "src": "/apb/queue_action(.*)",      "dest": "/api/apb/queue_action.php" },
        { "src": "/apb/search_patients(.*)",   "dest": "/api/apb/search_patients.php" },
        { "src": "/(.*)",                      "dest": "/api/index.php" }
    ]
}